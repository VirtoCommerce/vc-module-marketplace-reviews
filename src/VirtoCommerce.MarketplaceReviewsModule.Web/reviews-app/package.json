{
  "name": "reviews-app",
  "version": "1.1.1",
  "private": true,
  "scripts": {
    "serve": "cross-env APP_ENV=development vite --force",
    "preview": "vite preview",
    "build": "yarn build:app && yarn build:types && yarn build:modules-bundle",
    "build:app": "cross-env APP_ENV=production vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "build:modules-bundle": "vite build --config ./src/modules/vite.config.with-api.mts",
    "type-check": "vue-tsc --noEmit",
    "lint-staged": "lint-staged",
    "lint": "eslint --fix --cache '**/*.{ts,vue}'",
    "generate-api-client": "cross-env api-client-generator --APP_PLATFORM_MODULES='[VirtoCommerce.MarketplaceReviews]' --APP_API_CLIENT_DIRECTORY=./src/api_client/ --APP_PACKAGE_NAME=@vcmp-marketplace-reviews/api --APP_PACKAGE_VERSION=$npm_package_version --APP_TYPE_STYLE=Interface",
    "release": "tsx scripts/release.ts --dry"
  },
  "workspaces": [
    "src/api_client"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@laynezh/vite-plugin-lib-assets": "^0.5.13",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "@vc-shell/api-client-generator": "^2.0.2",
    "@vc-shell/ts-config": "^2.0.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "autoprefixer": "^10.4.16",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^10.4.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "lodash-es": "^4.17.21",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "sass": "^1.87.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-mkcert": "^1.17.1",
    "vue-eslint-parser": "^9.3.2",
    "vue-tsc": "^3.2.5"
  },
  "resolutions": {
    "@module-federation/dts-plugin": "2.0.1"
  },
  "dependencies": {
    "@vc-shell/config-generator": "^2.0.2",
    "@vc-shell/framework": "^2.0.2",
    "@vc-shell/mf-module": "^2.0.2",
    "@vueuse/core": "^10.7.1",
    "@vueuse/integrations": "^10.7.1",
    "cross-spawn": "^7.0.3",
    "moment": "^2.30.1",
    "vee-validate": "^4.12.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "lint-staged": {
    "*.{js,ts,html,css}": "prettier --write '**/*.{ts,vue}'",
    "*.{js,ts,vue}": "eslint --fix --cache '**/*.{ts,vue}'"
  },
  "packageManager": "yarn@4.0.2"
}
